# ---------------------------------------------------------------------------
# Wharf — environment variables
# Copy this file to .env.local for local development and fill in real values.
# See docs/ENVIRONMENT.md for a full description of each variable.
# ---------------------------------------------------------------------------

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL connection string)
# Local:   postgresql://postgres:postgres@localhost:5432/wharf
# Neon:    postgresql://user:pass@ep-xxxx.neon.tech/wharf?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wharf

# Clerk — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sentry (optional — leave blank to disable error tracking locally)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Seed script (optional — your own Clerk user id, for local seeding)
SEED_CLERK_USER_ID=
